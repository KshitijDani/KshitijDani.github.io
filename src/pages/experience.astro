---
import BaseLayout from '../layouts/BaseLayout.astro';
import { awards, education, experiences } from '../data/profile';
---

<BaseLayout title="Experience" description="Kshitij Dani's software engineering, AI research, education, and recognition.">
  <header class="page-intro">
    <div class="shell page-intro-grid">
      <div>
        <p class="eyebrow">Experience</p>
        <h1>Five years of production engineering, now applied to AI.</h1>
      </div>
      <div>
      <p>
        My path runs from mathematics and computer science through conversational AI, Microsoft-scale backend platforms, and current research into useful, trustworthy agents.
      </p>
      </div>
    </div>
  </header>

  <section class="page-section">
    <div class="shell">
      {experiences.map((experience) => (
        <article class="experience-group">
          <div class="experience-sticky">
            <p class="period">{experience.period}</p>
            <p class="period">{experience.location}</p>
          </div>
          <div class="experience-content">
            <h2>{experience.organization}</h2>
            <p class="experience-role">{experience.role}</p>
            <p class="experience-summary">{experience.summary}</p>
            <ul>
              {experience.highlights.map((highlight) => <li>{highlight}</li>)}
            </ul>
            <ul class="tag-list" aria-label="Technologies and focus areas">
              {experience.tags.map((tag) => <li>{tag}</li>)}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="page-section">
    <div class="shell split-grid">
      <div>
        <p class="eyebrow">Education</p>
        <div class="compact-list">
          {education.map((item) => (
            <article class="compact-item">
              <div class="compact-kicker"><span>{item.school}</span><span>{item.period}</span></div>
              <h3>{item.degree}</h3>
              <p>{item.detail}</p>
            </article>
          ))}
        </div>
      </div>
      <div>
        <p class="eyebrow">Recognition</p>
        <div class="compact-list">
          {awards.map((award) => (
            <article class="compact-item">
              <div class="compact-kicker"><span>{award.organization}</span><span>{award.year}</span></div>
              <h3>{award.title}</h3>
              <p>{award.detail}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
