---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found" noindex={true}>
  <section class="not-found shell">
    <div>
      <p class="eyebrow">Page not found</p>
      <h1>404</h1>
      <p>That page wandered off. <a class="text-link" href="/">Return home →</a></p>
    </div>
  </section>
</BaseLayout>
