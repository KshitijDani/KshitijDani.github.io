---
import BaseLayout from './BaseLayout.astro';
const { title, description, publishedAt, tags = [] } = Astro.props;
const date = publishedAt.toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
  timeZone: 'UTC',
});
const schema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: publishedAt.toISOString(),
  author: {
    '@type': 'Person',
    name: 'Kshitij Dani',
    url: 'https://kshitijdani.github.io',
  },
  keywords: tags.join(', '),
};
---

<BaseLayout title={title} description={description} type="article" {schema}>
  <article class="article-page shell-narrow">
    <header class="article-header">
      <a class="eyebrow back-link" href="/writing/">← Writing</a>
      <h1>{title}</h1>
      <p class="article-dek">{description}</p>
      <div class="article-meta">
        <time datetime={publishedAt.toISOString()}>{date}</time>
        {tags.length > 0 && <span>{tags.join(' · ')}</span>}
      </div>
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>
