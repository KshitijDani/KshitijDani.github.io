---
import type { CollectionEntry } from 'astro:content';
const { project, index = 0 } = Astro.props as { project: CollectionEntry<'work'>; index?: number };
---

<article class="project-card">
  <a class="project-card-link" href={`/work/${project.id}/`} aria-label={`Read case study: ${project.data.title}`}>
    <div class="project-card-topline">
      <span class="project-number">{String(index + 1).padStart(2, '0')}</span>
      <span>{project.data.kicker}</span>
    </div>
    <div class="project-card-body">
      <div>
        <h3>{project.data.title}</h3>
        <p>{project.data.description}</p>
      </div>
      <span class="project-arrow" aria-hidden="true">↗</span>
    </div>
    <div class="project-card-meta">
      <strong>{project.data.impact}</strong>
      <span>{project.data.period}</span>
    </div>
  </a>
</article>
